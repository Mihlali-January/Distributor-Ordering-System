<% content_for :title, "Admin Dashboard" %>

<div class="row g-4">
  <div class="col-md-4">
    <%= link_to admin_distributors_path, class: "text-decoration-none" do %>
      <div class="card-premium">
        <div class="card-icon">
          <i class="bi bi-people-fill"></i>
        </div>
        <h4 class="fw-bold text-dark">Distributors</h4>
        <p class="text-muted small">Manage global accounts, currencies, and regional logistics profiles.</p>
        <div class="d-flex align-items-center text-brand fw-bold small mt-4">
          MANAGE DISTRIBUTORS <i class="bi bi-arrow-right ms-2"></i>
        </div>
      </div>
    <% end %>
  </div>
  
  <div class="col-md-4">
    <%= link_to admin_products_path, class: "text-decoration-none" do %>
      <div class="card-premium">
        <div class="card-icon">
          <i class="bi bi-box-seam-fill"></i>
        </div>
        <h4 class="fw-bold text-dark">Products</h4>
        <p class="text-muted small">Maintain the global product catalog and volume specifications.</p>
        <div class="d-flex align-items-center text-brand fw-bold small mt-4">
          MANAGE CATALOG <i class="bi bi-arrow-right ms-2"></i>
        </div>
      </div>
    <% end %>
  </div>

  <div class="col-md-4">
    <%= link_to admin_orders_path, class: "text-decoration-none" do %>
      <div class="card-premium">
        <div class="card-icon">
          <i class="bi bi-cart-check-fill"></i>
        </div>
        <h4 class="fw-bold text-dark">Global Orders</h4>
        <p class="text-muted small">Monitor real-time bulk orders and logistics status across all regions.</p>
        <div class="d-flex align-items-center text-brand fw-bold small mt-4">
          VIEW ALL ORDERS <i class="bi bi-arrow-right ms-2"></i>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="container mt-5">
  <div class="row mb-4 align-items-center">
    <div class="col">
      <h1 class="mb-0">Admin Dashboard</h1>
      <p class="lead text-muted mb-0">Welcome, <%= current_user.full_name %></p>
    </div>
    <div class="col-auto">
      <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-outline-danger" %>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-4">
      <div class="card h-100 shadow-sm border-0">
        <div class="card-body">
          <h5 class="card-title fw-bold text-primary mb-3">
            <i class="bi bi-people-fill me-2"></i>Distributors
          </h5>
          <p class="card-text text-muted">Manage distributor accounts, set their currencies, and assign geographic product pricing.</p>
          <%= link_to "Manage Distributors", admin_distributors_path, class: "btn btn-primary w-100 mt-auto" %>
        </div>
      </div>
    </div>
    
    <div class="col-md-4">
      <div class="card h-100 shadow-sm border-0">
        <div class="card-body">
          <h5 class="card-title fw-bold text-success mb-3">
            <i class="bi bi-box-seam-fill me-2"></i>Products
          </h5>
          <p class="card-text text-muted">Create and edit the global Skincare Oil product catalog and volume specifications.</p>
          <%= link_to "Manage Products", admin_products_path, class: "btn btn-success w-100 mt-auto" %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card h-100 shadow-sm border-0 border-start border-4 border-warning">
        <div class="card-body">
          <h5 class="card-title fw-bold text-warning mb-3">
            <i class="bi bi-cart-check-fill me-2"></i>Global Orders
          </h5>
          <p class="card-text text-muted">Monitor all bulk orders across all distributors. Review pricing, volumes, and delivery dates.</p>
          <%= link_to "View All Orders", admin_orders_path, class: "btn btn-warning w-100 mt-auto text-white" %>
        </div>
      </div>
    </div>
  </div>
</div>

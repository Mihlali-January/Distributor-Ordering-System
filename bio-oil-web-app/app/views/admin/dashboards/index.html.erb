<div class="container mt-5">
  <div class="container mt-5">
  <div class="row mb-4">
    <div class="col">
      <h1>Admin Dashboard</h1>
      <p class="lead">Welcome, <%= current_user.email %></p>
    </div>
    <div class="col-auto">
      <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-outline-danger" %>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-4">
      <div class="card h-100 shadow-sm border-0">
        <div class="card-body">
          <h5 class="card-title">Distributors</h5>
          <p class="card-text">Manage distributor accounts, set their currencies, and assign product pricing.</p>
          <%= link_to "Manage Distributors", admin_distributors_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>
    
    <div class="col-md-4">
      <div class="card h-100 shadow-sm border-0">
        <div class="card-body">
          <h5 class="card-title">Products</h5>
          <p class="card-text">Create and edit the global Skincare Oil product catalog and volumes.</p>
          <%= link_to "Manage Products", admin_products_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

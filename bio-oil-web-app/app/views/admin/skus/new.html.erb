<% content_for :title, @sku.persisted? ? "Edit SKU Pricing" : "Add SKU" %>

<div class="mb-5 text-center">
  <%= link_to "&larr; Back to SKUs".html_safe, admin_distributor_skus_path(@distributor), class: "text-decoration-none text-muted mb-2 d-inline-block small fw-bold text-uppercase tracking-widest" %>
  <h1 class="brand-title" style="font-size: 3rem;"><%= @sku.persisted? ? "Edit SKU Pricing" : "Add SKU to Distributor" %></h1>
</div>

<div class="card-premium shadow-sm mx-auto" style="max-width: 600px;">
  <div class="card-body p-0">
    <%= form_with(model: [:admin, @distributor, @sku], local: true) do |f| %>
      <% if @sku.errors.any? %>
        <div class="alert alert-brand-error mb-4">
          <h6 class="alert-heading fw-bold"><%= pluralize(@sku.errors.count, "error") %> prohibited this SKU from being saved:</h6>
          <ul class="mb-0">
            <% @sku.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :product_id, "Select Product", class: "form-label fw-bold small text-uppercase tracking-widest text-muted" %>
        <%= f.collection_select :product_id, Product.all, :id, ->(prod) { "#{prod.name} (#{prod.volume})" }, { prompt: "Choose a product..." }, { class: "form-select form-control-brand", disabled: @sku.persisted? } %>
        <% if @sku.persisted? %>
          <div class="form-text small mt-2">You cannot change the underlying product of an existing SKU.</div>
        <% end %>
      </div>

      <div class="mb-5">
        <%= f.label :price_per_unit, "Price Per Unit (#{@distributor.currency})", class: "form-label fw-bold small text-uppercase tracking-widest text-muted" %>
        <div class="input-group">
          <span class="input-group-text border-0 bg-light fw-bold text-muted"><%= @distributor.currency %></span>
          <%= f.number_field :price_per_unit, step: "0.01", min: "0", class: "form-control form-control-brand", placeholder: "0.00", value: number_with_precision(f.object.price_per_unit, precision: 2) %>
        </div>
      </div>

      <div class="d-grid">
        <%= f.submit @sku.persisted? ? "Update Pricing" : "Create SKU", class: "btn btn-brand btn-lg py-3" %>
      </div>
    <% end %>
  </div>
</div>

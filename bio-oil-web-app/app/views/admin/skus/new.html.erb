<div class="container mt-5" style="max-width: 600px;">
  <div class="mb-4">
    <%= link_to "&larr; Back to SKUs".html_safe, admin_distributor_skus_path(@distributor), class: "text-decoration-none text-muted d-block mb-2" %>
    <h1><%= @sku.persisted? ? "Edit SKU Pricing" : "Add SKU to #{@distributor.name}" %></h1>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <%= form_with(model: [:admin, @distributor, @sku], local: true) do |f| %>
        <% if @sku.errors.any? %>
          <div class="alert alert-danger">
            <h6 class="alert-heading"><%= pluralize(@sku.errors.count, "error") %> prohibited this SKU from being saved:</h6>
            <ul class="mb-0">
              <% @sku.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :product_id, "Select Product", class: "form-label fw-bold" %>
          <%= f.collection_select :product_id, Product.all, :id, ->(prod) { "#{prod.name} (#{prod.volume})" }, { prompt: "Choose a product..." }, { class: "form-select", disabled: @sku.persisted? } %>
          <% if @sku.persisted? %>
            <div class="form-text">You cannot change the underlying product of an existing SKU.</div>
          <% end %>
        </div>

        <div class="mb-4">
          <%= f.label :price_per_unit, "Price Per Unit (#{@distributor.currency})", class: "form-label fw-bold" %>
          <div class="input-group">
            <span class="input-group-text"><%= @distributor.currency %></span>
            <%= f.number_field :price_per_unit, step: "0.01", min: "0", class: "form-control", placeholder: "0.00" %>
          </div>
        </div>

        <div class="d-grid">
          <%= f.submit @sku.persisted? ? "Update Pricing" : "Create SKU", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

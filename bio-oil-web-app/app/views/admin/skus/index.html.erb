<% content_for :title, "SKUs: #{@distributor.name}" %>

<div style="max-width: 1200px;">
  <div class="mb-4">
    <%= link_to "&larr; Back to Distributors".html_safe, admin_distributors_path, class: "text-decoration-none text-muted d-block mb-2 small fw-bold text-uppercase tracking-widest" %>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="mb-0 brand-title" style="font-size: 2.5rem;">SKUs for <%= @distributor.name %></h1>
      <p class="text-muted mt-2">Regional Logistics Pricing in <span class="badge bg-light text-dark border fw-bold px-3 py-2 rounded-pill"><%= @distributor.currency %></span></p>
    </div>
    <%= link_to "Add SKU to Distributor", new_admin_distributor_sku_path(@distributor), class: "btn btn-brand" %>
  </div>

  <div class="table-clean shadow-sm">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>SKU Code</th>
          <th>Product</th>
          <th>Volume</th>
          <th class="text-end">Price Per Unit (<%= @distributor.currency %>)</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @skus.each do |sku| %>
          <tr>
            <td class="fw-bold text-brand text-uppercase tracking-wider small"><%= sku.sku_code %></td>
            <td class="fw-bold text-dark"><%= sku.product.name %></td>
            <td><%= sku.product.volume %></td>
            <td class="text-end fw-bold text-dark"><%= number_to_currency(sku.price_per_unit, unit: @distributor.currency + " ", precision: 2) %></td>
            <td class="text-end">
              <%= link_to "Edit Price", edit_admin_distributor_sku_path(@distributor, sku), class: "btn btn-sm btn-outline-dark px-3 rounded-pill" %>
            </td>
          </tr>
        <% end %>
        
        <% if @skus.empty? %>
          <tr>
            <td colspan="5" class="text-center py-5 text-muted">No SKUs have been configured for this distributor yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

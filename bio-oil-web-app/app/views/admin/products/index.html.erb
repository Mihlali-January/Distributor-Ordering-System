<% content_for :title, "Products Catalog" %>

<div style="max-width: 1200px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="brand-title mb-0" style="font-size: 2.5rem;">Products Catalog</h1>
    </div>
    <%= link_to "Add New Product", new_admin_product_path, class: "btn btn-brand" %>
  </div>

  <div class="table-clean shadow-sm">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>Product Name</th>
          <th>Volume</th>
          <th class="text-center">Associated SKUs</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td class="fw-bold text-dark"><%= product.name %></td>
            <td><%= product.volume %></td>
            <td class="text-center">
              <span class="badge bg-light text-dark border fw-bold px-3 py-2 rounded-pill shadow-sm">
                <%= product.skus.count %> SKUs Globally
              </span>
            </td>
            <td class="text-end">
              <%= link_to "Edit", edit_admin_product_path(product), class: "btn btn-sm btn-outline-dark ms-1 rounded-pill px-4" %>
            </td>
          </tr>
        <% end %>
        
        <% if @products.empty? %>
          <tr>
            <td colspan="4" class="text-center py-5 text-muted">No products created yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="container mt-5" style="max-width: 600px;">
  <div class="mb-4">
    <%= link_to "&larr; Back to Products".html_safe, admin_products_path, class: "text-decoration-none text-muted d-block mb-2" %>
    <h1><%= @product.persisted? ? "Edit Product" : "New Product" %></h1>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <%= form_with(model: [:admin, @product], local: true) do |f| %>
        <% if @product.errors.any? %>
          <div class="alert alert-danger">
            <h6 class="alert-heading"><%= pluralize(@product.errors.count, "error") %> prohibited this product from being saved:</h6>
            <ul class="mb-0">
              <% @product.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :name, "Base Product Name", class: "form-label fw-bold" %>
          <%= f.text_field :name, class: "form-control", placeholder: "e.g., Skincare Oil 60ml" %>
          <div class="form-text">This will be the standard name derived by all global SKUs.</div>
        </div>

        <div class="mb-4">
          <%= f.label :volume, "Volume", class: "form-label fw-bold" %>
          <%= f.select :volume, Product::VALID_VOLUMES, { prompt: "Select a Product Volume" }, class: "form-select" %>
        </div>

        <div class="d-grid">
          <%= f.submit class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

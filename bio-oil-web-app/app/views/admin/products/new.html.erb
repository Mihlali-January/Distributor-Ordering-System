<% content_for :title, @product.persisted? ? "Edit Product" : "New Product" %>

<div class="mb-5 text-center">
  <%= link_to "&larr; Back to Products".html_safe, admin_products_path, class: "text-decoration-none text-muted d-inline-block mb-2 small fw-bold text-uppercase tracking-widest" %>
  <h1 class="mb-0 brand-title" style="font-size: 3rem;"><%= @product.persisted? ? "Edit Product" : "New Product" %></h1>
</div>

<div class="card-premium mx-auto" style="max-width: 600px;">
  <%= form_with(model: [:admin, @product], local: true) do |f| %>
    <% if @product.errors.any? %>
      <div class="alert alert-brand-error">
        <h6 class="alert-heading fw-bold"><%= pluralize(@product.errors.count, "error") %> prohibited this product from being saved:</h6>
        <ul class="mb-0">
          <% @product.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :name, "Base Product Name", class: "form-label fw-bold small text-uppercase tracking-widest text-muted" %>
      <%= f.text_field :name, class: "form-control form-control-brand", placeholder: "e.g., Skincare Oil 60ml" %>
      <div class="form-text small mt-2">This will be the standard name derived by all global SKUs.</div>
    </div>

    <div class="mb-5">
      <%= f.label :volume, "Volume Specification", class: "form-label fw-bold small text-uppercase tracking-widest text-muted" %>
      <%= f.select :volume, Product::VALID_VOLUMES, { prompt: "Select a Product Volume" }, class: "form-select form-control-brand" %>
    </div>

    <div class="d-grid">
      <%= f.submit class: "btn btn-brand btn-lg" %>
    </div>
  <% end %>
</div>

<% content_for :title, @distributor.name %>

<div style="max-width: 1200px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <%= link_to "&larr; Back to Distributors".html_safe, admin_distributors_path, class: "text-decoration-none text-muted mb-2 d-block small fw-bold text-uppercase tracking-widest" %>
      <h1 class="mb-0" style="font-size: 1.75rem; font-weight: 700;"><%= @distributor.name %></h1>
      <div class="mt-2 d-flex align-items-center">
        <span class="text-muted small text-uppercase tracking-widest fw-bold me-2">Code:</span>
        <span class="badge bg-light text-brand border me-3 fw-bold"><%= @distributor.distributor_code %></span>
        <span class="text-muted small text-uppercase tracking-widest fw-bold me-2">Status:</span>
        <% if @distributor.active? %>
          <span class="badge bg-success-subtle text-success border border-success-subtle px-3 rounded-pill">Active</span>
        <% else %>
          <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 rounded-pill">Inactive</span>
        <% end %>
      </div>
    </div>
    <div>
      <%= link_to "Edit Account", edit_admin_distributor_path(@distributor), class: "btn btn-outline-dark rounded-pill px-4 shadow-sm" %>
      <%= link_to "Manage SKUs", admin_distributor_skus_path(@distributor), class: "btn btn-brand ms-2 shadow-sm rounded-pill px-4", style: "text-transform: none; font-size: 0.875rem;" %>
      <%= button_to "Delete", admin_distributor_path(@distributor),
          method: :delete,
          form: { data: { turbo_confirm: "Are you sure you want to delete #{@distributor.name}? This will permanently delete all their users, SKUs and orders." } },
          class: "btn btn-outline-danger rounded-pill px-4 shadow-sm ms-2" %>
    </div>
  </div>

  <div class="row g-4 mt-2">
    <div class="col-md-7">
      <div class="card-premium mb-4 h-100">
        <h5 class="fw-bold mb-4 text-uppercase tracking-widest text-muted" style="font-size: 0.75rem;">Logistics Profile</h5>
        <div class="row mb-4">
          <div class="col-sm-4 text-muted small text-uppercase tracking-widest fw-bold">Street Address</div>
          <div class="col-sm-8 text-dark fw-medium"><%= simple_format(@distributor.address) %></div>
        </div>
        <div class="row mb-4">
          <div class="col-sm-4 text-muted small text-uppercase tracking-widest fw-bold">Tax / VAT ID</div>
          <div class="col-sm-8 fw-bold text-dark"><%= @distributor.tax_number || "Not specified" %></div>
        </div>
        <div class="row mb-0">
          <div class="col-sm-4 text-muted small text-uppercase tracking-widest fw-bold">Settlement Currency</div>
          <div class="col-sm-8"><span class="badge bg-light text-dark border fw-bold px-3 py-2"><%= @distributor.currency %></span></div>
        </div>
      </div>
    </div>

    <div class="col-md-5">
      <div class="card-premium h-100 border-top border-4 border-brand">
        <h5 class="fw-bold mb-4 text-uppercase tracking-widest text-muted" style="font-size: 0.75rem;">Primary Contact</h5>
        <h4 class="mb-1 text-dark fw-bold"><%= @distributor.contact_name || "No contact name" %></h4>
        <p class="text-muted small text-uppercase tracking-widest mb-4">Account Relationship Manager</p>
        
        <div class="d-flex align-items-center mb-4">
          <div class="icon-circle bg-brand-light text-brand me-3">
            <i class="bi bi-envelope-fill"></i>
          </div>
          <%= mail_to @distributor.contact_email, nil, class: "text-decoration-none text-dark fw-medium h6 mb-0" %>
        </div>
        <div class="d-flex align-items-center">
          <div class="icon-circle bg-brand-light text-brand me-3">
            <i class="bi bi-telephone-fill"></i>
          </div>
          <span class="fw-bold h6 mb-0 text-dark"><%= @distributor.contact_phone || "No phone number" %></span>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mt-2">
    <div class="col-md-7">
      <h5 class="fw-bold mb-3 mt-4 text-uppercase tracking-widest text-muted" style="font-size: 0.75rem;">Authorized Personnel</h5>
      <div class="table-clean shadow-sm">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>Full Name</th>
              <th>Username</th>
              <th>Email Address</th>
            </tr>
          </thead>
          <tbody>
            <% @distributor.users.each do |user| %>
              <tr>
                <td class="fw-bold text-dark"><%= user.full_name %></td>
                <td><code class="text-brand"><%= user.username %></code></td>
                <td class="text-muted"><%= user.email %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="col-md-5">
      <div class="card-premium mt-4">
        <h5 class="fw-bold mb-4 text-uppercase tracking-widest text-muted" style="font-size: 0.75rem;">Direct Procurement</h5
        <div class="d-flex justify-content-between align-items-center mb-4">
          <span class="text-muted fw-bold small text-uppercase tracking-widest">Active Regional SKUs</span>
          <span class="stat-value text-brand" style="font-size: 3rem;"><%= @distributor.skus.count %></span>
        </div>
        <div class="d-grid mt-2">
          <%= link_to admin_distributor_skus_path(@distributor), class: "btn py-3 fw-bold tracking-widest btn-brand-light" do %>
            VIEW PRICING CATALOG <i class='bi bi-arrow-right ms-2'></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

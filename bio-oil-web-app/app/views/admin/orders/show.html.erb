<% content_for :title, "Order #{@order.order_number}" %>

<div style="max-width: 1200px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <%= link_to "&larr; Back to All Orders".html_safe, admin_orders_path, class: "text-decoration-none text-muted mb-2 d-block small fw-bold text-uppercase tracking-widest" %>
      <h1 class="mb-0 brand-title" style="font-size: 3rem;">Order <%= @order.order_number %></h1>
      <p class="text-muted mt-2">Distributor: <%= @order.distributor.display_name %></p>
    </div>
    <%= link_to "Back to All Orders", admin_orders_path, class: "btn btn-outline-dark rounded-pill px-4" %>
  </div>

  <div class="row g-4 mt-2">
    <div class="col-md-8">
      <h5 class="fw-bold mb-4">Order Items</h5>
      <div class="table-clean shadow-sm">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>SKU / Product</th>
              <th class="text-center">Pallets</th>
              <th class="text-center">Units</th>
              <th class="text-end">Cost</th>
            </tr>
          </thead>
          <tbody>
            <% @order.order_items.each do |item| %>
              <tr>
                <td>
                  <strong class="text-brand"><%= item.sku.product.name %></strong><br>
                  <span class="text-muted small text-uppercase tracking-wider"><%= item.sku.sku_code %></span>
                </td>
                <td class="text-center"><%= item.pallets %></td>
                <td class="text-center"><%= number_with_delimiter(item.units) %></td>
                <td class="text-end fw-medium"><%= number_to_currency(item.cost, unit: @order.distributor.currency + " ") %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot style="background-color: #fdfdfd; border-top: 1px solid rgba(0,0,0,0.05);">
            <tr>
              <td colspan="3" class="text-end fw-bold text-uppercase tracking-widest pt-4">Grand Total</td>
              <td class="text-end fw-bold text-brand fs-4 pt-4 pe-4">
                <%= number_to_currency(@order.total_cost, unit: @order.distributor.currency + " ") %>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card-premium h-100">
        <h5 class="fw-bold mb-4">Order Details</h5>
        <div class="mb-4">
          <label class="text-muted small text-uppercase tracking-widest d-block mb-1">Placed By</label>
          <div class="fw-bold"><%= @order.user.full_name %></div>
          <div class="text-muted small"><%= @order.user.email %></div>
        </div>
        <div class="mb-4">
          <label class="text-muted small text-uppercase tracking-widest d-block mb-1">Order Date</label>
          <div class="fw-bold">
            <i class="bi bi-calendar3 me-2 text-brand"></i>
            <%= @order.created_at.strftime("%B %d, %Y") %>
          </div>
          <div class="text-muted small"><%= @order.created_at.strftime("%H:%M") %> (UTC)</div>
        </div>
        <div class="mb-0">
          <label class="text-muted small text-uppercase tracking-widest d-block mb-1">Required Delivery</label>
          <div class="fw-bold text-brand p-2 bg-brand-light rounded border border-brand-subtle d-inline-block">
            <i class="bi bi-truck me-2"></i>
            <%= @order.required_delivery_date.strftime("%B %d, %Y") %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

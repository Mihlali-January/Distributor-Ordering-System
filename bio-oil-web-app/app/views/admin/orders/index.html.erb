<% content_for :title, "Global Orders" %>

<div style="max-width: 1200px;">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="brand-title mb-0">Global Orders</h1>
    <%= link_to "Back to Dashboard", admin_root_path, class: "btn btn-outline-dark rounded-pill px-4" %>
  </div>

  <div class="table-clean shadow-sm">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>Order #</th>
          <th>Distributor</th>
          <th>Placed By</th>
          <th>Date</th>
          <th>Total Cost</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td class="fw-bold"><%= order.order_number %></td>
            <td><%= order.distributor.display_name %></td>
            <td class="small text-muted"><%= order.user.full_name %></td>
            <td><%= order.created_at.strftime("%d %b %Y") %></td>
            <td class="fw-medium">
              <%= number_to_currency(order.total_cost, unit: order.distributor.currency + " ") %>
            </td>
            <td class="text-end">
              <%= link_to "View", admin_order_path(order), class: "btn btn-sm btn-outline-dark px-3 rounded-pill" %>
            </td>
          </tr>
        <% end %>

        <% if @orders.empty? %>
          <tr>
            <td colspan="6" class="text-center py-5 text-muted">No orders found in the system.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

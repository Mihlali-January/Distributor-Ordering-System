<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Global Orders</h1>
    <%= link_to "Back to Dashboard", admin_root_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body p-0">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Order #</th>
            <th>Distributor</th>
            <th>Placed By</th>
            <th>Date</th>
            <th>Total Cost</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr>
              <td class="align-middle fw-bold"><%= order.order_number %></td>
              <td class="align-middle"><%= order.distributor.display_name %></td>
              <td class="align-middle small text-muted"><%= order.user.full_name %></td>
              <td class="align-middle"><%= order.created_at.strftime("%d %b %Y") %></td>
              <td class="align-middle fw-medium">
                <%= number_to_currency(order.total_cost, unit: order.distributor.currency + " ") %>
              </td>
              <td class="text-end align-middle">
                <%= link_to "View", admin_order_path(order), class: "btn btn-sm btn-outline-primary" %>
              </td>
            </tr>
          <% end %>

          <% if @orders.empty? %>
            <tr>
              <td colspan="6" class="text-center py-5 text-muted">No orders found in the system.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="glass-card text-center">
  <div class="mb-5">
    <h6 class="text-brand tracking-widest uppercase mb-1">Welcome Back</h6>
    <h1 class="h2 fw-light tracking-widest mb-0 uppercase text-brand">Bio-Oil<span class="fw-bold">®</span></h1>
    <p class="small text-muted tracking-widest uppercase">Distributor Ordering Portal</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "text-start", novalidate: true }) do |f| %>
    <div class="mb-4">
      <%= f.label :email, class: "form-label small text-brand tracking-widest uppercase fw-bold" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control-brand w-100", placeholder: "Enter your email" %>
    </div>

    <div class="mb-4">
      <div class="d-flex justify-content-between align-items-center">
        <%= f.label :password, class: "form-label small text-brand tracking-widest uppercase fw-bold" %>
      </div>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-control-brand w-100", placeholder: "••••••••" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="mb-4 form-check text-start">
        <%= f.check_box :remember_me, class: "form-check-input" %>
        <%= f.label :remember_me, class: "form-check-label small text-muted text-uppercase tracking-widest" %>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.submit "Sign In", class: "btn-brand w-100" %>
    </div>
  <% end %>

  <div class="mt-4 border-top pt-4">
    <%= render "devise/shared/links" %>
  </div>
</div>

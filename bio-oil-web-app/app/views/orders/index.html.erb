<% content_for :title, "Order History" %>

<div style="max-width: 1200px;">
  <div class="row g-4 mb-5">
    <div class="col-md-4">
      <div class="card-premium">
        <div class="card-icon">
          <i class="bi bi-cart"></i>
        </div>
        <div class="stat-value"><%= @order_count %></div>
        <div class="stat-label">TOTAL ORDERS</div>
      </div>
    </div>
    
    <div class="col-md-4">
      <div class="card-premium">
        <div class="card-icon">
          <i class="bi bi-cash-stack"></i>
        </div>
        <div class="stat-value">
          <%= number_to_currency(@total_spent, unit: current_user.distributor.currency + " ") %>
        </div>
        <div class="stat-label">TOTAL PORTAL SPEND</div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card-premium d-flex flex-column justify-content-center align-items-center text-center">
        <h5 class="fw-bold mb-3">Ready for more?</h5>
        <%= link_to new_order_path, class: "btn btn-brand w-100 py-2" do %>
          PLACE NEW ORDER <i class="bi bi-box-arrow-in-right ms-2"></i>
        <% end %>
      </div>
    </div>
  </div>

  <div class="table-clean shadow-sm">
    <table class="table mb-0">
      <thead>
        <tr>
          <th>Order #</th>
          <th>Placed On</th>
          <th>Required Delivery</th>
          <th>Total Cost</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td class="fw-bold"><%= order.order_number %></td>
            <td class="text-muted"><%= order.created_at.strftime("%d %b %Y") %></td>
            <td><%= order.required_delivery_date.strftime("%d %b %Y") %></td>
            <td class="fw-bold text-dark">
              <%= number_to_currency(order.total_cost, unit: order.distributor.currency + " ") %>
            </td>
            <td class="text-end">
              <%= link_to "View Details", order_path(order), class: "btn btn-sm btn-outline-dark px-3 rounded-pill" %>
            </td>
          </tr>
        <% end %>

        <% if @orders.empty? %>
          <tr>
            <td colspan="5" class="text-center py-5">
              <div class="text-muted mb-3">No orders placed yet.</div>
              <%= link_to "Start your first order", new_order_path, class: "btn btn-brand btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="container mt-5" style="max-width: 900px;">
  <div class="mb-4 d-flex justify-content-between align-items-end">
    <div>
      <%= link_to "&larr; Back to Order History".html_safe, orders_path, class: "text-decoration-none text-muted mb-2 d-block" %>
      <h1>Order <%= @order.order_number %></h1>
      <p class="text-muted mb-0">Placed by <%= @order.user.email %> on <%= @order.created_at.strftime("%B %d, %Y") %></p>
    </div>
    <div class="text-end">
      <div class="badge bg-success fs-6 mb-2">Confirmed</div>
      <div class="text-muted small">Required Delivery: <strong><%= @order.required_delivery_date.strftime("%B %d, %Y") %></strong></div>
    </div>
  </div>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white py-3 border-bottom-0">
      <h5 class="mb-0 fw-bold text-secondary">Items Summary</h5>
    </div>
    <div class="card-body p-0">
      <table class="table mb-0">
        <thead class="table-light">
          <tr>
            <th>SKU / Product</th>
            <th class="text-center">Pallets</th>
            <th class="text-center">Total Units</th>
            <th class="text-end">Line Cost (<%= @order.distributor.currency %>)</th>
          </tr>
        </thead>
        <tbody>
          <% @order.order_items.each do |item| %>
            <tr>
              <td class="align-middle">
                <div class="fw-bold"><%= item.sku.sku_code %></div>
                <div class="small text-muted"><%= item.sku.product.name %> (<%= item.sku.product.volume %>)</div>
              </td>
              <td class="text-center align-middle"><%= item.pallets %></td>
              <td class="text-center align-middle text-muted"><%= number_with_delimiter(item.units) %></td>
              <td class="text-end align-middle fw-medium">
                <%= number_to_currency(item.cost, unit: @order.distributor.currency + " ") %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="table-light">
          <tr>
            <th colspan="3" class="text-end py-3">Total Order Cost</th>
            <th class="text-end py-3 text-primary h4 mb-0">
              <%= number_to_currency(@order.total_cost, unit: @order.distributor.currency + " ") %>
            </th>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="alert alert-info border-0 shadow-sm d-flex align-items-center">
    <div class="me-3">
      <i class="bi bi-info-circle-fill fs-4"></i>
    </div>
    <div>
      <strong>Note:</strong> This order has been logged into the Union Swiss global tracking system. You will receive an email once shipment is scheduled.
    </div>
  </div>
</div>

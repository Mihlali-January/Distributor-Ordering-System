<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bio-Oil | Authentication" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Bio-Oil Web App">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
  </head>

  <body class="auth-layout">
    <div class="auth-wrapper">
      <div class="auth-background" style="background-image: url('<%= asset_path('login-bg.png') %>');"></div>
      <div class="auth-overlay"></div>
      
      <div class="auth-content d-flex flex-column align-items-center justify-content-center min-vh-100 p-4 w-100">
        <div class="flash-container mb-4 w-100" style="max-width: 450px;">
          <% flash.each do |type, message| %>
            <div class="alert alert-brand-<%= type == 'notice' ? 'notice' : 'error' %> text-center shadow-sm">
              <%= message %>
            </div>
          <% end %>
        </div>
        <%= yield %>
      </div>
    </div>
  </body>
</html>
